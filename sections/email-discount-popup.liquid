<link rel="stylesheet" href="{{ 'email-discount-popup.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'email-discount-popup.css' | asset_url | stylesheet_tag }}</noscript>

{%- liquid
  assign popup_image = section.settings.image
  assign discount_code = section.settings.discount_code | strip
  assign popup_id = 'EmailDiscountPopup-' | append: section.id
  assign form_id = 'EmailDiscountForm-' | append: section.id
-%}

<email-discount-popup
  id="{{ popup_id }}"
  class="m-email-discount-popup"
  data-section-id="{{ section.id }}"
  data-enable="{{ section.settings.enable }}"
  data-design-mode="{{ section.settings.design_mode }}"
  data-delay="{{ section.settings.delay_seconds | times: 1000 }}"
  data-dismiss-days="{{ section.settings.dismiss_days }}"
  data-discount-code="{{ discount_code }}"
>
  <div class="m-modal m-modal--wrapper" role="dialog" aria-modal="true" aria-label="{{ section.settings.heading | escape }}">
    <div class="m-modal--content">
      <div class="m-modal--content-inner">
        <button class="m-email-discount-popup__close" type="button" aria-label="Close popup" data-email-popup-close>
          <svg class="m-svg-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M5 5L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <div class="m-email-discount-popup__layout">
          <div class="m-email-discount-popup__media">
            {% if popup_image != blank %}
              {{
                popup_image
                | image_url: width: 1200
                | image_tag:
                  loading: 'lazy',
                  sizes: '(max-width: 767px) 100vw, 40vw',
                  widths: '375, 550, 750, 900, 1200',
                  alt: popup_image.alt
              }}
            {% else %}
              <div class="m-email-discount-popup__placeholder">
                Join the Kingsteam List
              </div>
            {% endif %}
          </div>

          <div class="m-email-discount-popup__content">
            {% if section.settings.eyebrow != blank %}
              <p class="m-email-discount-popup__eyebrow">{{ section.settings.eyebrow }}</p>
            {% endif %}

            {% if section.settings.heading != blank %}
              <h2 class="m-email-discount-popup__heading">{{ section.settings.heading }}</h2>
            {% endif %}

            {% if discount_code != blank %}
              <div class="m-email-discount-popup__discount">
                {{ section.settings.discount_label }} {{ discount_code }}
              </div>
            {% endif %}

            {% if section.settings.text != blank %}
              <div class="m-email-discount-popup__text rte">{{ section.settings.text }}</div>
            {% endif %}

            {% form 'customer', id: form_id, class: 'm-email-discount-popup__form' %}
              {% if form.posted_successfully? %}
                <div class="m-email-discount-popup__success" data-email-popup-success>
                  {% if section.settings.success_heading != blank %}
                    <h3 class="m-email-discount-popup__heading">{{ section.settings.success_heading }}</h3>
                  {% endif %}

                  {% if section.settings.success_text != blank %}
                    <div class="m-email-discount-popup__text rte">{{ section.settings.success_text }}</div>
                  {% endif %}

                  {% if discount_code != blank %}
                    <div class="m-email-discount-popup__success-code">
                      <div>
                        <strong>{{ section.settings.success_code_label }}</strong>
                        <span>{{ discount_code }}</span>
                      </div>
                      <button type="button" class="m-email-discount-popup__copy" data-email-popup-copy>
                        Copy
                      </button>
                    </div>
                  {% endif %}

                  <button type="button" class="m-email-discount-popup__action" data-email-popup-close>
                    {{ section.settings.success_button_label }}
                  </button>
                </div>
              {% else %}
                {% render 'form__error', form: form %}
                <input type="hidden" name="contact[tags]" value="newsletter,discount-popup">
                <div class="m-email-discount-popup__field">
                  <input
                    type="email"
                    name="contact[email]"
                    id="{{ form_id }}-email"
                    value="{% if customer.email != blank %}{{ customer.email }}{% endif %}"
                    placeholder="{{ section.settings.email_placeholder }}"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    spellcheck="false"
                    required
                  >
                  <button type="submit" name="commit">
                    {{ section.settings.submit_label }}
                  </button>
                </div>

                {% if section.settings.fine_print != blank %}
                  <div class="m-email-discount-popup__fine-print rte">{{ section.settings.fine_print }}</div>
                {% endif %}

                <button type="button" class="m-email-discount-popup__dismiss" data-email-popup-close>
                  {{ section.settings.dismiss_label }}
                </button>
              {% endif %}
            {% endform %}
          </div>
        </div>
      </div>
    </div>
  </div>
</email-discount-popup>

<script src="{{ 'email-discount-popup.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Email discount popup",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "paragraph",
      "content": "Enable design mode to always show the popup in the theme editor while you are adjusting the content."
    },
    {
      "type": "checkbox",
      "id": "design_mode",
      "label": "Design mode",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "range",
      "id": "delay_seconds",
      "label": "Delay before showing",
      "min": 0,
      "max": 15,
      "step": 1,
      "unit": "s",
      "default": 2
    },
    {
      "type": "range",
      "id": "dismiss_days",
      "label": "Show again after close",
      "min": 1,
      "max": 30,
      "step": 1,
      "unit": "days",
      "default": 7
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Welcome offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% off your first order"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Join our email list to unlock a welcome discount for your next Kingsteam order.</p>"
    },
    {
      "type": "text",
      "id": "discount_label",
      "label": "Discount label",
      "default": "Unlock code:"
    },
    {
      "type": "text",
      "id": "discount_code",
      "label": "Discount code to reveal",
      "default": "WELCOME10"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Get my code"
    },
    {
      "type": "richtext",
      "id": "fine_print",
      "label": "Fine print",
      "default": "<p>By signing up, you agree to receive marketing emails. You can unsubscribe anytime.</p>"
    },
    {
      "type": "text",
      "id": "dismiss_label",
      "label": "Dismiss label",
      "default": "No thanks"
    },
    {
      "type": "header",
      "content": "Success state"
    },
    {
      "type": "text",
      "id": "success_heading",
      "label": "Success heading",
      "default": "You're in"
    },
    {
      "type": "richtext",
      "id": "success_text",
      "label": "Success text",
      "default": "<p>Thanks for joining. Use the code below at checkout to claim your welcome discount.</p>"
    },
    {
      "type": "text",
      "id": "success_code_label",
      "label": "Success code label",
      "default": "Your code"
    },
    {
      "type": "text",
      "id": "success_button_label",
      "label": "Success button label",
      "default": "Continue shopping"
    }
  ]
}
{% endschema %}
