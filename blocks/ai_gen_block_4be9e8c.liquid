{% doc %}
  @prompt
    Image with text slider. The image should take up about 40% of the space on the left. The text should be in the middle of the right section., Add a "shop now" botton below the text. make the text aligned both on the left and on the right., the button is not visible. check why., make the size of the image adjustable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-image-text-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-image-text-slider__track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-image-text-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
  }

  .ai-image-text-slider__image-container-{{ ai_gen_id }} {
    width: {{ block.settings.image_width }}%;
    flex-shrink: 0;
  }

  .ai-image-text-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-slider__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-text-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-image-text-slider__content-container-{{ ai_gen_id }} {
    width: calc(100% - {{ block.settings.image_width }}%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-image-text-slider__content-{{ ai_gen_id }} {
    max-width: 600px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-slider__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-image-text-slider__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.text_spacing }}px;
    text-align: justify;
  }

  .ai-image-text-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
    border: 1px solid {{ block.settings.button_bg_color }};
  }

  .ai-image-text-slider__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-image-text-slider__controls-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: {{ block.settings.controls_spacing }}px;
  }

.ai-image-text-slider__arrow-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-image-text-slider__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
    color: {{ block.settings.arrow_hover_color }};
  }

  .ai-image-text-slider__arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-image-text-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-image-text-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-image-text-slider__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-slider__slide-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-image-text-slider__image-container-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-image-text-slider__content-container-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-image-text-slider__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-image-text-slider__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-text-slider-{{ ai_gen_id }}
  class="ai-image-text-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-slider__wrapper-{{ ai_gen_id }}">
    <div class="ai-image-text-slider__track-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign slide_image_key = 'slide_' | append: i | append: '_image'
          assign slide_heading_key = 'slide_' | append: i | append: '_heading'
          assign slide_text_key = 'slide_' | append: i | append: '_text'
          assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
          assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign slide_image = block.settings[slide_image_key]
          assign slide_heading = block.settings[slide_heading_key]
          assign slide_text = block.settings[slide_text_key]
          assign slide_button_text = block.settings[slide_button_text_key]
          assign slide_button_link = block.settings[slide_button_link_key]
        %}

        {% if slide_enabled %}
          <div class="ai-image-text-slider__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            <div class="ai-image-text-slider__image-container-{{ ai_gen_id }}">
              <div class="ai-image-text-slider__image-wrapper-{{ ai_gen_id }}">
                {% if slide_image %}
                  <img
                    src="{{ slide_image | image_url: width: 1000 }}"
                    alt="{{ slide_image.alt | escape }}"
                    class="ai-image-text-slider__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="{{ slide_image.width }}"
                    height="{{ slide_image.height }}"
                  >
                {% else %}
                  <div class="ai-image-text-slider__image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
            </div>

            <div class="ai-image-text-slider__content-container-{{ ai_gen_id }}">
              <div class="ai-image-text-slider__content-{{ ai_gen_id }}">
                {% if slide_heading != blank %}
                  <h2 class="ai-image-text-slider__heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
                {% endif %}

                {% if slide_text != blank %}
                  <div class="ai-image-text-slider__text-{{ ai_gen_id }}">{{ slide_text }}</div>
                {% endif %}

                {% if slide_button_text != blank %}
                  <a
                    href="{% if slide_button_link != blank %}{{ slide_button_link }}{% else %}#{% endif %}"
                    class="ai-image-text-slider__button-{{ ai_gen_id }}"
                  >
                    {{ slide_button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if block.settings.show_controls %}
    <div class="ai-image-text-slider__controls-{{ ai_gen_id }}">
      <button
        class="ai-image-text-slider__arrow-{{ ai_gen_id }} ai-image-text-slider__arrow-prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-image-text-slider__dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-image-text-slider__arrow-{{ ai_gen_id }} ai-image-text-slider__arrow-next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  {% endif %}
</image-text-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-image-text-slider__track-{{ ai_gen_id }}');
        this.slideElements = this.querySelectorAll('.ai-image-text-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-text-slider__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-image-text-slider__arrow-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-image-text-slider__dots-{{ ai_gen_id }}');

        this.slides = Array.from(this.slideElements);

        if (this.slides.length === 0) return;

        this.createDots();
        this.setupEventListeners();
        this.updateSlider();

        {% if block.settings.enable_autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-image-text-slider__dot-{{ ai_gen_id }}');
          dot.setAttribute('aria-label', 'Go to slide ' + (index + 1));
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        {% if block.settings.enable_autoplay %}
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        {% endif %}
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
      }

      previousSlide() {
        this.currentSlide = this.currentSlide === 0 ? this.slides.length - 1 : this.currentSlide - 1;
        this.updateSlider();
      }

      nextSlide() {
        this.currentSlide = this.currentSlide === this.slides.length - 1 ? 0 : this.currentSlide + 1;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = 'translateX(' + offset + '%)';

        if (this.prevButton) {
          this.prevButton.disabled = false;
        }

        if (this.nextButton) {
          this.nextButton.disabled = false;
        }

        const dots = this.querySelectorAll('.ai-image-text-slider__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('image-text-slider-{{ ai_gen_id }}', ImageTextSlider{{ ai_gen_id }});
  })();
</script>

