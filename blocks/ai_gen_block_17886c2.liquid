{% doc %}
  @prompt
    A heading with an animated glowing effect
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glow-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-glow-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
    display: inline-block;
    position: relative;
    text-shadow: 
      0 0 {{ block.settings.glow_blur }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_blur | times: 2 }}px {{ block.settings.glow_color }},
      0 0 {{ block.settings.glow_blur | times: 3 }}px {{ block.settings.glow_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-glow-heading__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-glow-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
  {% else %}
    <h2 class="ai-glow-heading__text-{{ ai_gen_id }}">
      Add your heading text
    </h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Glowing heading",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading text",
      "default": "Glowing Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 60
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#000f9f"
    },
    {
      "type": "range",
      "id": "glow_blur",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Glow intensity",
      "default": 20
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Glowing heading"
    }
  ],
  "tag": null
}
{% endschema %}
