{% doc %}
  @prompt
    A holographic product card slider. The slider should be mobile compatible, meaning that it should be responsive and adapt to mobile layout. The product cards should be swipable on mobile, each swipe flips exactly ONE product card. Give more customizable parameters.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-holo-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
  }

  .ai-holo-slider__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-holo-slider__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-holo-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
  }

  .ai-holo-slider__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-holo-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    touch-action: pan-y;
    user-select: none;
  }

  .ai-holo-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_desktop | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_desktop }});
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.card_background }};
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-holo-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 0, 255, {{ block.settings.holo_intensity }}) 0%,
      rgba(0, 255, 255, {{ block.settings.holo_intensity }}) 25%,
      rgba(255, 255, 0, {{ block.settings.holo_intensity }}) 50%,
      rgba(0, 255, 0, {{ block.settings.holo_intensity }}) 75%,
      rgba(255, 0, 255, {{ block.settings.holo_intensity }}) 100%
    );
    background-size: 200% 200%;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 2;
  }

  .ai-holo-card-{{ ai_gen_id }}:hover::before {
    opacity: 1;
    animation: ai-holo-shift-{{ ai_gen_id }} {{ block.settings.holo_animation_speed }}s ease infinite;
  }

  @keyframes ai-holo-shift-{{ ai_gen_id }} {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .ai-holo-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background: {{ block.settings.image_placeholder_bg }};
  }

  .ai-holo-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-holo-card-{{ ai_gen_id }}:hover .ai-holo-card__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-holo-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    left: {{ block.settings.badge_position_left }}px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    z-index: 3;
  }

  .ai-holo-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    position: relative;
    z-index: 1;
  }

  .ai-holo-card__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_font_size }}px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-holo-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.title_line_clamp }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-holo-card__price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-holo-card__price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-holo-card__price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-holo-card__button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-holo-card__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-holo-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-holo-slider__arrow-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    background: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-holo-slider__arrow-{{ ai_gen_id }}:hover {
    background: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
    transform: scale(1.1);
  }

  .ai-holo-slider__arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-holo-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-holo-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-holo-slider__dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-holo-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-holo-card__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-holo-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_tablet | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_tablet }});
    }

    .ai-holo-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-holo-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_mobile | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_mobile }});
    }

    .ai-holo-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-holo-slider-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 0 {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<holographic-slider-{{ ai_gen_id }} class="ai-holo-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-holo-slider__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-holo-slider__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-holo-slider__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-holo-slider__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-holo-slider__track-{{ ai_gen_id }}" data-track>
      {% if block.settings.products != blank %}
        {% for product in block.settings.products %}
          <div class="ai-holo-card-{{ ai_gen_id }}">
            <div class="ai-holo-card__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-holo-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
              {% else %}
                <div class="ai-holo-card__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_badge and product.available == false %}
                <div class="ai-holo-card__badge-{{ ai_gen_id }}">{{ block.settings.sold_out_text }}</div>
              {% elsif block.settings.show_badge and product.compare_at_price > product.price %}
                <div class="ai-holo-card__badge-{{ ai_gen_id }}">{{ block.settings.sale_text }}</div>
              {% endif %}
            </div>

            <div class="ai-holo-card__content-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <p class="ai-holo-card__vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
              {% endif %}

              <h3 class="ai-holo-card__title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">
                  {{ product.title }}
                </a>
              </h3>

              {% if block.settings.show_price %}
                <div class="ai-holo-card__price-{{ ai_gen_id }}">
                  <span class="ai-holo-card__price-current-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </span>
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-holo-card__price-compare-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.show_button %}
                <a href="{{ product.url }}" class="ai-holo-card__button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        {% for i in (1..6) %}
          <div class="ai-holo-card-{{ ai_gen_id }}">
            <div class="ai-holo-card__image-wrapper-{{ ai_gen_id }}">
              <div class="ai-holo-card__placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            </div>
            <div class="ai-holo-card__content-{{ ai_gen_id }}">
              <h3 class="ai-holo-card__title-{{ ai_gen_id }}">Product {{ i }}</h3>
              <div class="ai-holo-card__price-{{ ai_gen_id }}">
                <span class="ai-holo-card__price-current-{{ ai_gen_id }}">$99.00</span>
              </div>
              <a href="#" class="ai-holo-card__button-{{ ai_gen_id }}">{{ block.settings.button_text }}</a>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if block.settings.show_navigation %}
      <div class="ai-holo-slider__nav-{{ ai_gen_id }}">
        <button class="ai-holo-slider__arrow-{{ ai_gen_id }}" data-prev aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        {% if block.settings.show_dots %}
          <div class="ai-holo-slider__dots-{{ ai_gen_id }}" data-dots></div>
        {% endif %}

        <button class="ai-holo-slider__arrow-{{ ai_gen_id }}" data-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</holographic-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HolographicSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDragging = false;
        this.startPos = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.animationID = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.cards = Array.from(this.track.children);
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');

        this.cardsPerView = this.getCardsPerView();
        this.totalSlides = Math.ceil(this.cards.length / this.cardsPerView);

        this.setupEventListeners();
        this.createDots();
        this.updateSlider();
      }

      getCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) return {{ block.settings.cards_per_row_mobile }};
        if (width <= 989) return {{ block.settings.cards_per_row_tablet }};
        return {{ block.settings.cards_per_row_desktop }};
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prev());
        }
        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.next());
        }

        this.track.addEventListener('touchstart', this.touchStart.bind(this), { passive: true });
        this.track.addEventListener('touchend', this.touchEnd.bind(this));
        this.track.addEventListener('touchmove', this.touchMove.bind(this), { passive: true });

        this.track.addEventListener('mousedown', this.touchStart.bind(this));
        this.track.addEventListener('mouseup', this.touchEnd.bind(this));
        this.track.addEventListener('mouseleave', this.touchEnd.bind(this));
        this.track.addEventListener('mousemove', this.touchMove.bind(this));

        window.addEventListener('resize', () => {
          this.cardsPerView = this.getCardsPerView();
          this.totalSlides = Math.ceil(this.cards.length / this.cardsPerView);
          this.currentIndex = Math.min(this.currentIndex, this.totalSlides - 1);
          this.createDots();
          this.updateSlider();
        });
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-holo-slider__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      touchStart(event) {
        this.isDragging = true;
        this.startPos = this.getPositionX(event);
        this.animationID = requestAnimationFrame(this.animation.bind(this));
        this.track.style.cursor = 'grabbing';
      }

      touchMove(event) {
        if (this.isDragging) {
          const currentPosition = this.getPositionX(event);
          this.currentTranslate = this.prevTranslate + currentPosition - this.startPos;
        }
      }

      touchEnd() {
        this.isDragging = false;
        cancelAnimationFrame(this.animationID);
        this.track.style.cursor = 'grab';

        const movedBy = this.currentTranslate - this.prevTranslate;

        if (movedBy < -100 && this.currentIndex < this.totalSlides - 1) {
          this.currentIndex += 1;
        }

        if (movedBy > 100 && this.currentIndex > 0) {
          this.currentIndex -= 1;
        }

        this.updateSlider();
      }

      getPositionX(event) {
        return event.type.includes('mouse') ? event.pageX : event.touches[0].clientX;
      }

      animation() {
        if (this.isDragging) {
          this.track.style.transform = `translateX(${this.currentTranslate}px)`;
          requestAnimationFrame(this.animation.bind(this));
        }
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        if (this.currentIndex < this.totalSlides - 1) {
          this.currentIndex++;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        const cardWidth = this.cards[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * this.cardsPerView * (cardWidth + gap));

        this.currentTranslate = offset;
        this.prevTranslate = offset;
        this.track.style.transform = `translateX(${offset}px)`;

        if (this.prevBtn) {
          this.prevBtn.disabled = this.currentIndex === 0;
        }
        if (this.nextBtn) {
          this.nextBtn.disabled = this.currentIndex === this.totalSlides - 1;
        }

        if (this.dotsContainer) {
          const dots = this.dotsContainer.querySelectorAll('.ai-holo-slider__dot-{{ ai_gen_id }}');
          dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === this.currentIndex);
          });
        }
      }
    }

    customElements.define('holographic-slider-{{ ai_gen_id }}', HolographicSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Holographic slider",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "select",
      "id": "cards_per_row_desktop",
      "label": "Cards per row (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "cards_per_row_tablet",
      "label": "Cards per row (tablet)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Heading style"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Spacing below heading",
      "default": 30
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Holographic effect"
    },
    {
      "type": "range",
      "id": "holo_intensity",
