{% doc %}
  @prompt
    A holographic product card slider. The slider should be mobile compatible, meaning that it should be responsive and adapt to mobile layout. The product cards should be swipable on mobile, each swipe flips exactly ONE product card. Give more customizable parameters.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-holo-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
  }

  .ai-holo-slider__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-holo-slider__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-holo-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 10px;
  }

  .ai-holo-slider__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-holo-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    touch-action: pan-y;
    user-select: none;
    will-change: transform;
  }

  .ai-holo-slider__viewport-{{ ai_gen_id }} {
    overflow: hidden;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
    padding: 6px 0;
  }

  .ai-holo-slider__viewport-{{ ai_gen_id }}.is-dragging {
    cursor: grabbing;
  }

  .ai-holo-card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_desktop | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_desktop }});
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background: {{ block.settings.card_background }};
    cursor: pointer;
    transition: transform 0.3s ease;
    border: 2.5px solid rgba(89, 74, 56, 0.28);
    box-shadow: 0 14px 28px rgba(67, 53, 38, 0.08);
  }

  .ai-holo-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      rgba(245, 239, 229, {{ block.settings.holo_intensity }}) 0%,
      rgba(232, 221, 205, {{ block.settings.holo_intensity }}) 25%,
      rgba(220, 204, 182, {{ block.settings.holo_intensity }}) 50%,
      rgba(205, 184, 158, {{ block.settings.holo_intensity }}) 75%,
      rgba(245, 239, 229, {{ block.settings.holo_intensity }}) 100%
    );
    background-size: 200% 200%;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 2;
  }

  .ai-holo-card-{{ ai_gen_id }}:hover::before {
    opacity: 1;
    animation: ai-holo-shift-{{ ai_gen_id }} {{ block.settings.holo_animation_speed }}s ease infinite;
  }

  .ai-holo-card-{{ ai_gen_id }}:hover {
    border-color: rgba(89, 74, 56, 0.42);
    transform: translateY(-4px);
  }

  @keyframes ai-holo-shift-{{ ai_gen_id }} {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .ai-holo-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background: {{ block.settings.image_placeholder_bg }};
  }

  .ai-holo-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-holo-card__image-main-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-holo-card__image-hover-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-holo-card-{{ ai_gen_id }}:hover .ai-holo-card__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-holo-card-{{ ai_gen_id }}:hover .ai-holo-card__image-main-{{ ai_gen_id }} {
    opacity: 0;
  }

  .ai-holo-card-{{ ai_gen_id }}:hover .ai-holo-card__image-hover-{{ ai_gen_id }} {
    opacity: 1;
  }

  .ai-holo-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    left: {{ block.settings.badge_position_left }}px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    z-index: 3;
  }

  .ai-holo-card__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    position: relative;
    z-index: 1;
  }

  .ai-holo-card__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_font_size }}px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-holo-card__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.title_line_clamp }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-holo-card__price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .ai-holo-card__price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-holo-card__price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-holo-card__button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .ai-holo-card__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-holo-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-holo-slider__arrow-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    background: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-holo-slider__arrow-{{ ai_gen_id }}:hover {
    background: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
    transform: scale(1.1);
  }

  .ai-holo-slider__arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-holo-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-holo-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-holo-slider__dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-holo-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-holo-card__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-holo-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_tablet | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_tablet }});
    }

    .ai-holo-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-holo-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_mobile | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_mobile }});
    }

    .ai-holo-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-holo-slider-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 0 {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<holographic-slider-{{ ai_gen_id }} class="ai-holo-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-holo-slider__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-holo-slider__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-holo-slider__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-holo-slider__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-holo-slider__viewport-{{ ai_gen_id }}" data-viewport>
      <div class="ai-holo-slider__track-{{ ai_gen_id }}" data-track>
        {% if block.settings.products != blank %}
          {% for product in block.settings.products %}
          {% liquid
            assign hover_image = blank

            for image in product.images
              if image.id != product.featured_image.id
                assign hover_image = image
                break
              endif
            endfor
          %}
          <div class="ai-holo-card-{{ ai_gen_id }}">
            <div class="ai-holo-card__image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-holo-card__image-{{ ai_gen_id }} ai-holo-card__image-main-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                >
                {% if hover_image != blank %}
                  <img
                    src="{{ hover_image | image_url: width: 600 }}"
                    alt="{{ hover_image.alt | default: product.title | escape }}"
                    class="ai-holo-card__image-{{ ai_gen_id }} ai-holo-card__image-hover-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                  >
                {% endif %}
              {% else %}
                <div class="ai-holo-card__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_badge and product.available == false %}
                <div class="ai-holo-card__badge-{{ ai_gen_id }}">{{ block.settings.sold_out_text }}</div>
              {% elsif block.settings.show_badge and product.compare_at_price > product.price %}
                <div class="ai-holo-card__badge-{{ ai_gen_id }}">{{ block.settings.sale_text }}</div>
              {% endif %}
            </div>

            <div class="ai-holo-card__content-{{ ai_gen_id }}">
              {% if block.settings.show_vendor and product.vendor != blank %}
                <p class="ai-holo-card__vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
              {% endif %}

              <h3 class="ai-holo-card__title-{{ ai_gen_id }}">
                <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">
                  {{ product.title }}
                </a>
              </h3>

              {% if block.settings.show_price %}
                <div class="ai-holo-card__price-{{ ai_gen_id }}">
                  <span class="ai-holo-card__price-current-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </span>
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-holo-card__price-compare-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>
              {% endif %}

              {% if block.settings.show_button %}
                <a href="{{ product.url }}" class="ai-holo-card__button-{{ ai_gen_id }}">
                  {{ block.settings.button_text }}
                </a>
              {% endif %}
            </div>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <div class="ai-holo-card-{{ ai_gen_id }}">
              <div class="ai-holo-card__image-wrapper-{{ ai_gen_id }}">
                <div class="ai-holo-card__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              </div>
              <div class="ai-holo-card__content-{{ ai_gen_id }}">
                <h3 class="ai-holo-card__title-{{ ai_gen_id }}">Product {{ i }}</h3>
                <div class="ai-holo-card__price-{{ ai_gen_id }}">
                  <span class="ai-holo-card__price-current-{{ ai_gen_id }}">$99.00</span>
                </div>
                <a href="#" class="ai-holo-card__button-{{ ai_gen_id }}">{{ block.settings.button_text }}</a>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if block.settings.show_navigation %}
      <div class="ai-holo-slider__nav-{{ ai_gen_id }}">
        <button class="ai-holo-slider__arrow-{{ ai_gen_id }}" data-prev aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        {% if block.settings.show_dots %}
          <div class="ai-holo-slider__dots-{{ ai_gen_id }}" data-dots></div>
        {% endif %}

        <button class="ai-holo-slider__arrow-{{ ai_gen_id }}" data-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</holographic-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HolographicSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.isDragging = false;
        this.dragMoved = false;
        this.interactiveSelector = 'a, button, input, select, textarea, label';
        this.startX = 0;
        this.dragTranslate = 0;
        this.prevTranslate = 0;
        this.cardsPerView = 1;
        this.cloneCount = 0;
        this.boundResize = this.handleResize.bind(this);
        this.boundTransitionEnd = this.handleTransitionEnd.bind(this);
        this.boundPointerDown = this.handlePointerDown.bind(this);
        this.boundPointerMove = this.handlePointerMove.bind(this);
        this.boundPointerUp = this.handlePointerUp.bind(this);
        this.boundTrackClick = this.handleTrackClick.bind(this);
      }

      connectedCallback() {
        this.viewport = this.querySelector('[data-viewport]');
        this.track = this.querySelector('[data-track]');
        this.prevBtn = this.querySelector('[data-prev]');
        this.nextBtn = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');

        if (!this.track) return;
        this.originalCards = Array.from(this.track.children).map((card) => card.cloneNode(true));
        if (this.originalCards.length === 0) return;

        this.setupSlider();
        this.setupEventListeners();
      }

      getCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) return {{ block.settings.cards_per_row_mobile }};
        if (width <= 989) return {{ block.settings.cards_per_row_tablet }};
        return {{ block.settings.cards_per_row_desktop }};
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prev());
        }
        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.next());
        }

        if (this.viewport) {
          this.viewport.addEventListener('pointerdown', this.boundPointerDown);
          this.viewport.addEventListener('pointermove', this.boundPointerMove);
          this.viewport.addEventListener('pointerup', this.boundPointerUp);
          this.viewport.addEventListener('pointerleave', this.boundPointerUp);
          this.viewport.addEventListener('pointercancel', this.boundPointerUp);
          this.viewport.addEventListener('dragstart', (event) => event.preventDefault());
        }

        this.track.addEventListener('transitionend', this.boundTransitionEnd);
        this.track.addEventListener('click', this.boundTrackClick, true);
        window.addEventListener('resize', this.boundResize);
      }

      setupSlider(preserveIndex = 0) {
        this.cardsPerView = this.getCardsPerView();
        this.cloneCount = Math.min(Math.max(this.cardsPerView, 1), this.originalCards.length);
        this.track.innerHTML = '';

        const leadingCards = this.originalCards.slice(-this.cloneCount).map((card) => this.createCardClone(card));
        const mainCards = this.originalCards.map((card) => card.cloneNode(true));
        const trailingCards = this.originalCards.slice(0, this.cloneCount).map((card) => this.createCardClone(card));

        [...leadingCards, ...mainCards, ...trailingCards].forEach((card) => this.track.appendChild(card));

        this.cards = Array.from(this.track.children);
        this.currentIndex = this.cloneCount + Math.min(preserveIndex, this.originalCards.length - 1);
        this.createDots();
        this.updatePosition(false);
        this.updateDots();
      }

      createCardClone(card) {
        const clone = card.cloneNode(true);
        clone.dataset.clone = 'true';
        return clone;
      }

      getCardGap() {
        const trackStyles = window.getComputedStyle(this.track);
        return parseFloat(trackStyles.columnGap || trackStyles.gap || 0);
      }

      getStepSize() {
        const referenceCard = this.cards[this.cloneCount];
        if (!referenceCard) return 0;
        return referenceCard.getBoundingClientRect().width + this.getCardGap();
      }

      getTranslateForIndex(index) {
        return -(this.getStepSize() * index);
      }

      getRealIndex() {
        if (this.originalCards.length === 0) return 0;
        let realIndex = (this.currentIndex - this.cloneCount) % this.originalCards.length;
        if (realIndex < 0) realIndex += this.originalCards.length;
        return realIndex;
      }

      createDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.originalCards.length; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-holo-slider__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateDots() {
        if (!this.dotsContainer) return;
        const activeIndex = this.getRealIndex();
        const dots = this.dotsContainer.querySelectorAll('.ai-holo-slider__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === activeIndex);
        });
      }

      updatePosition(animate = true) {
        const targetTranslate = this.getTranslateForIndex(this.currentIndex);
        this.prevTranslate = targetTranslate;
        this.dragTranslate = targetTranslate;
        this.track.style.transition = animate ? 'transform 0.45s cubic-bezier(0.22, 1, 0.36, 1)' : 'none';
        this.track.style.transform = `translate3d(${targetTranslate}px, 0, 0)`;
      }

      handleTransitionEnd() {
        if (
          this.currentIndex >= this.originalCards.length + this.cloneCount ||
          this.currentIndex < this.cloneCount
        ) {
          this.currentIndex = this.cloneCount + this.getRealIndex();
          this.updatePosition(false);
        }
        this.updateDots();
      }

      handlePointerDown(event) {
        if (event.pointerType === 'mouse' && event.button !== 0) return;
        if (event.target.closest(this.interactiveSelector)) return;
        this.isDragging = true;
        this.dragMoved = false;
        this.startX = event.clientX;
        this.dragTranslate = this.getTranslateForIndex(this.currentIndex);
        this.prevTranslate = this.dragTranslate;
        this.track.style.transition = 'none';
        if (this.viewport) {
          this.viewport.classList.add('is-dragging');
          if (this.viewport.setPointerCapture) {
            this.viewport.setPointerCapture(event.pointerId);
          }
        }
      }

      handlePointerMove(event) {
        if (!this.isDragging) return;
        const delta = event.clientX - this.startX;
        if (Math.abs(delta) > 6) {
          this.dragMoved = true;
        }
        this.dragTranslate = this.prevTranslate + delta;
        this.track.style.transform = `translate3d(${this.dragTranslate}px, 0, 0)`;
      }

      handlePointerUp(event) {
        if (!this.isDragging) return;

        this.isDragging = false;
        if (this.viewport) {
          this.viewport.classList.remove('is-dragging');
          if (this.viewport.releasePointerCapture) {
            try {
              this.viewport.releasePointerCapture(event.pointerId);
            } catch (error) {
            }
          }
        }

        const movedBy = this.dragTranslate - this.prevTranslate;
        const stepSize = this.getStepSize();
        if (!stepSize) {
          this.updatePosition(true);
          return;
        }
        const movedCards = Math.round(Math.abs(movedBy) / stepSize);

        if (movedBy < -stepSize / 5) {
          this.currentIndex += Math.max(1, movedCards);
        } else if (movedBy > stepSize / 5) {
          this.currentIndex -= Math.max(1, movedCards);
        }

        this.updatePosition(true);
        this.updateDots();

        window.setTimeout(() => {
          this.dragMoved = false;
        }, 0);
      }

      handleTrackClick(event) {
        if (this.dragMoved) {
          event.preventDefault();
          event.stopPropagation();
        }
      }

      handleResize() {
        const realIndex = this.getRealIndex();
        this.setupSlider(realIndex);
      }

      prev() {
        this.currentIndex -= 1;
        this.updatePosition(true);
        this.updateDots();
      }

      next() {
        this.currentIndex += 1;
        this.updatePosition(true);
        this.updateDots();
      }

      goToSlide(index) {
        let delta = index - this.getRealIndex();
        const loopDelta =
          delta > 0 ? delta - this.originalCards.length : delta + this.originalCards.length;
        if (Math.abs(loopDelta) < Math.abs(delta)) {
          delta = loopDelta;
        }
        this.currentIndex += delta;
        this.updatePosition(true);
        this.updateDots();
      }

      disconnectedCallback() {
        if (this.viewport) {
          this.viewport.removeEventListener('pointerdown', this.boundPointerDown);
          this.viewport.removeEventListener('pointermove', this.boundPointerMove);
          this.viewport.removeEventListener('pointerup', this.boundPointerUp);
          this.viewport.removeEventListener('pointerleave', this.boundPointerUp);
          this.viewport.removeEventListener('pointercancel', this.boundPointerUp);
        }
        if (this.track) {
          this.track.removeEventListener('transitionend', this.boundTransitionEnd);
          this.track.removeEventListener('click', this.boundTrackClick, true);
        }
        window.removeEventListener('resize', this.boundResize);
      }
    }

    customElements.define('holographic-slider-{{ ai_gen_id }}', HolographicSlider{{ ai_gen_id }});
  })();
</script>

