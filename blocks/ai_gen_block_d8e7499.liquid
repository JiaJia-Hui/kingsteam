{% doc %}
  @prompt
    A holographic product card slider. The header should be customizable, and the products should be mobile compatible. give more customizable parameters.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-holographic-slider-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-holographic-slider__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-holographic-slider__header-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.header_margin_bottom }}px;
    text-align: {{ block.settings.header_alignment }};
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: {{ block.settings.heading_size }}px;
    letter-spacing: var(--font-heading-spacing);
    color: rgb(var(--color-heading-text));
  }


  .ai-holographic-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-family: '', sans-serif; 
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 600;
  }

  .ai-holographic-slider__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-holographic-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-holographic-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    transition: transform 0.5s ease;
  }

  .ai-holographic-slider__card-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.card_gap | times: block.settings.cards_per_row | minus: block.settings.card_gap }}px) / {{ block.settings.cards_per_row }});
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-holographic-slider__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-holographic-slider__card-inner-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-holographic-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background: {{ block.settings.image_placeholder_bg }};
  }

  .ai-holographic-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-holographic-slider__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-holographic-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-holographic-slider__holographic-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba(255, 0, 255, {{ block.settings.holographic_opacity }}) 0%,
      rgba(0, 255, 255, {{ block.settings.holographic_opacity }}) 25%,
      rgba(255, 255, 0, {{ block.settings.holographic_opacity }}) 50%,
      rgba(0, 255, 0, {{ block.settings.holographic_opacity }}) 75%,
      rgba(255, 0, 255, {{ block.settings.holographic_opacity }}) 100%
    );
    background-size: 200% 200%;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    mix-blend-mode: {{ block.settings.blend_mode }};
  }

  .ai-holographic-slider__card-{{ ai_gen_id }}:hover .ai-holographic-slider__holographic-overlay-{{ ai_gen_id }} {
    opacity: 1;
    animation: ai-holographic-shift-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease infinite;
  }

  @keyframes ai-holographic-shift-{{ ai_gen_id }} {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .ai-holographic-slider__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-holographic-slider__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 {{ block.settings.vendor_spacing }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-holographic-slider__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-holographic-slider__price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .ai-holographic-slider__price-regular-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-holographic-slider__price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-holographic-slider__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    left: {{ block.settings.badge_position_left }}px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_size }}px;
    font-weight: 600;
    z-index: 2;
  }

  .ai-holographic-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-holographic-slider__nav-button-{{ ai_gen_id }} {
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    background: {{ block.settings.nav_button_bg }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-holographic-slider__nav-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_button_hover_bg }};
    color: {{ block.settings.nav_button_hover_color }};
  }

  .ai-holographic-slider__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-holographic-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-holographic-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-holographic-slider__dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 1024px) {
    .ai-holographic-slider__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: block.settings.cards_per_row_tablet | minus: block.settings.card_gap }}px) / {{ block.settings.cards_per_row_tablet }});
    }
  }

  @media screen and (max-width: 768px) {
    .ai-holographic-slider__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - {{ block.settings.card_gap | times: block.settings.cards_per_row_mobile | minus: block.settings.card_gap }}px) / {{ block.settings.cards_per_row_mobile }});
    }

    .ai-holographic-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-holographic-slider__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<holographic-product-slider-{{ ai_gen_id }} class="ai-holographic-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-holographic-slider__container-{{ ai_gen_id }}">
    {% if block.settings.show_header %}
      <div class="ai-holographic-slider__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-holographic-slider__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-holographic-slider__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-holographic-slider__wrapper-{{ ai_gen_id }}">
      <div class="ai-holographic-slider__track-{{ ai_gen_id }}" data-track>
        {% if block.settings.product_list != blank %}
          {% for product in block.settings.product_list %}
            <div class="ai-holographic-slider__card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-holographic-slider__card-inner-{{ ai_gen_id }}">
                <div class="ai-holographic-slider__image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-holographic-slider__image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="600"
                      height="{{ 600 | times: block.settings.image_aspect_ratio | divided_by: 100 }}"
                    >
                  {% else %}
                    <div class="ai-holographic-slider__image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                  <div class="ai-holographic-slider__holographic-overlay-{{ ai_gen_id }}"></div>
                  
                  {% if block.settings.show_sale_badge and product.compare_at_price > product.price %}
                    <div class="ai-holographic-slider__badge-{{ ai_gen_id }}">
                      {% if block.settings.sale_badge_type == 'percentage' %}
                        {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
                        -{{ discount }}%
                      {% else %}
                        {{ block.settings.sale_badge_text }}
                      {% endif %}
                    </div>
                  {% endif %}
                </div>

                <div class="ai-holographic-slider__content-{{ ai_gen_id }}">
                  {% if block.settings.show_vendor and product.vendor != blank %}
                    <div class="ai-holographic-slider__vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
                  {% endif %}

                  <h3 class="ai-holographic-slider__product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

                  <div class="ai-holographic-slider__price-{{ ai_gen_id }}">
                    <span class="ai-holographic-slider__price-regular-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-holographic-slider__price-compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% endif %}
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        {% else %}
          {% for i in (1..6) %}
            <div class="ai-holographic-slider__card-{{ ai_gen_id }}">
              <div class="ai-holographic-slider__card-inner-{{ ai_gen_id }}">
                <div class="ai-holographic-slider__image-wrapper-{{ ai_gen_id }}">
                  <div class="ai-holographic-slider__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                  <div class="ai-holographic-slider__holographic-overlay-{{ ai_gen_id }}"></div>
                </div>
                <div class="ai-holographic-slider__content-{{ ai_gen_id }}">
                  <h3 class="ai-holographic-slider__product-title-{{ ai_gen_id }}">Product {{ i }}</h3>
                  <div class="ai-holographic-slider__price-{{ ai_gen_id }}">
                    <span class="ai-holographic-slider__price-regular-{{ ai_gen_id }}">$29.99</span>
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    {% if block.settings.show_navigation %}
      <div class="ai-holographic-slider__nav-{{ ai_gen_id }}">
        <button class="ai-holographic-slider__nav-button-{{ ai_gen_id }}" data-prev aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        {% if block.settings.show_dots %}
          <div class="ai-holographic-slider__dots-{{ ai_gen_id }}" data-dots></div>
        {% endif %}

        <button class="ai-holographic-slider__nav-button-{{ ai_gen_id }}" data-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</holographic-product-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HolographicProductSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.cardsPerView = {{ block.settings.cards_per_row }};
        this.autoplayInterval = null;
        this.enableLoop = {{ block.settings.enable_loop }};
      }

      connectedCallback() {
        this.track = this.querySelector('[data-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.cards = this.querySelectorAll('.ai-holographic-slider__card-{{ ai_gen_id }}');
        
        this.updateCardsPerView();
        this.setupNavigation();
        this.setupDots();
        this.updateSlider();
        
        {% if block.settings.enable_autoplay %}
          this.startAutoplay();
          this.track.addEventListener('mouseenter', () => this.stopAutoplay());
          this.track.addEventListener('mouseleave', () => this.startAutoplay());
        {% endif %}

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.updateSlider();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 768) {
          this.cardsPerView = {{ block.settings.cards_per_row_mobile }};
        } else if (width <= 1024) {
          this.cardsPerView = {{ block.settings.cards_per_row_tablet }};
        } else {
          this.cardsPerView = {{ block.settings.cards_per_row }};
        }
      }

      setupNavigation() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }
      }

      setupDots() {
        if (!this.dotsContainer) return;
        
        const totalSlides = Math.ceil(this.cards.length / this.cardsPerView);
        this.dotsContainer.innerHTML = '';
        
        for (let i = 0; i < totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-holographic-slider__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === 0) dot.classList.add('active');
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateSlider() {
        const cardWidth = this.cards[0]?.offsetWidth || 0;
        const gap = {{ block.settings.card_gap }};
        const offset = -(this.currentIndex * this.cardsPerView * (cardWidth + gap));
        
        this.track.style.transform = 'translateX(' + offset + 'px)';
        
        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }
        if (this.nextButton) {
          const maxIndex = Math.ceil(this.cards.length / this.cardsPerView) - 1;
          this.nextButton.disabled = this.currentIndex >= maxIndex;
        }
        
        this.updateDots();
      }

      updateDots() {
        if (!this.dotsContainer) return;
        
        const dots = this.dotsContainer.querySelectorAll('.ai-holographic-slider__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.updateSlider();
        }
      }

      next() {
        const maxIndex = Math.ceil(this.cards.length / this.cardsPerView) - 1;
        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.updateSlider();
        } else if (this.enableLoop) {
          this.currentIndex = 0;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentIndex = index;
        this.updateSlider();
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.next();
        }, {{ block.settings.autoplay_speed | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('holographic-product-slider-{{ ai_gen_id }}', HolographicProductSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Holographic slider",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#222222"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "header_spacing",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Bottom spacing",
      "default": 40
    },
    {
      "type": "range",
      "id": "subheading_spacing",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Subheading spacing",
      "default": 10
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "cards_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Cards per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "cards_per_row_tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Cards per row (tablet)",
      "default": 3
    },
    {
      "type": "select",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding bottom",
      "default": 50
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "hover_lift",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Hover lift",
      "default": 8
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "image_aspect_ratio",
