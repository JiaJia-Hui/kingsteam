{% doc %}
  @prompt
    A holographic product card slider. The slider should be mobile compatible, meaning that it should be responsive and adapt to mobile layout. The product cards should be scrollable on mobile. Give more customizable parameters., The pictures of the products are not showing. Doublecheck.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-holo-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-holo-slider__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-holo-slider__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-holo-slider__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.subheading_spacing }}px;
    font-weight: 600;
  }

  .ai-holo-slider__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-holo-slider__wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin: 0 -{{ block.settings.card_gap }}px;
  }

  .ai-holo-slider__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    padding: {{ block.settings.card_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-holo-slider__track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-holo-slider__card-{{ ai_gen_id }} {
    position: relative;
    flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_desktop | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_desktop }});
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .ai-holo-slider__card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      {{ block.settings.holographic_angle }}deg,
      {{ block.settings.holo_color_1 }} 0%,
      {{ block.settings.holo_color_2 }} 25%,
      {{ block.settings.holo_color_3 }} 50%,
      {{ block.settings.holo_color_4 }} 75%,
      {{ block.settings.holo_color_1 }} 100%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: {{ block.settings.blend_mode }};
  }

  .ai-holo-slider__card-{{ ai_gen_id }}:hover::before {
    opacity: {{ block.settings.holographic_opacity | divided_by: 100.0 }};
  }

  .ai-holo-slider__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-holo-slider__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background: {{ block.settings.image_background }};
    display: block;
  }

  .ai-holo-slider__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-holo-slider__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-holo-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-holo-slider__card-{{ ai_gen_id }}:hover .ai-holo-slider__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_zoom | divided_by: 100.0 }});
  }

  .ai-holo-slider__content-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.card_padding }}px;
    z-index: 2;
  }

  .ai-holo-slider__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 {{ block.settings.vendor_spacing }}px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-holo-slider__product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    font-weight: 600;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.title_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-holo-slider__price-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: {{ block.settings.price_spacing }}px;
  }

  .ai-holo-slider__price-current-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 700;
  }

  .ai-holo-slider__price-compare-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-holo-slider__badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.badge_position_top }}px;
    left: {{ block.settings.badge_position_left }}px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding }}px {{ block.settings.badge_padding | times: 1.5 }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_size }}px;
    font-weight: 600;
    z-index: 3;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-holo-slider__button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-align: center;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-holo-slider__button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-holo-slider__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.nav_spacing }}px;
  }

  .ai-holo-slider__nav-button-{{ ai_gen_id }} {
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    background: {{ block.settings.nav_button_background }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-holo-slider__nav-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.nav_button_hover_background }};
    color: {{ block.settings.nav_button_hover_color }};
    transform: scale(1.1);
  }

  .ai-holo-slider__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-holo-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-holo-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .ai-holo-slider__dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  .ai-holo-slider__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.subheading_color }};
  }

  .ai-holo-slider__empty-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: 400px;
    margin: 0 auto 20px;
    background: #f5f5f5;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
  }

  .ai-holo-slider__empty-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 989px) {
    .ai-holo-slider__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_tablet | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_tablet }});
    }

    .ai-holo-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-holo-slider__card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.cards_per_row_mobile | minus: 1 }} * {{ block.settings.card_gap }}px)) / {{ block.settings.cards_per_row_mobile }});
    }

    .ai-holo-slider__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-holo-slider__product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-holo-slider__nav-{{ ai_gen_id }} {
      gap: 15px;
    }
  }
{% endstyle %}

<holographic-slider-{{ ai_gen_id }} class="ai-holo-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-holo-slider__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank or block.settings.subheading != blank %}
      <div class="ai-holo-slider__header-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-holo-slider__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="ai-holo-slider__subtitle-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.product_list != blank %}
      <div class="ai-holo-slider__wrapper-{{ ai_gen_id }}">
        <div class="ai-holo-slider__track-{{ ai_gen_id }}" data-slider-track>
          {% for product in block.settings.product_list %}
            <div class="ai-holo-slider__card-{{ ai_gen_id }}">
              {% if block.settings.show_badge and product.available == false %}
                <div class="ai-holo-slider__badge-{{ ai_gen_id }}">{{ block.settings.sold_out_text }}</div>
              {% elsif block.settings.show_badge and product.compare_at_price > product.price %}
                <div class="ai-holo-slider__badge-{{ ai_gen_id }}">{{ block.settings.sale_text }}</div>
              {% endif %}

              <a href="{{ product.url }}" class="ai-holo-slider__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-holo-slider__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
                  >
                {% else %}
                  <div class="ai-holo-slider__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </a>

              <div class="ai-holo-slider__content-{{ ai_gen_id }}">
                {% if block.settings.show_vendor and product.vendor != blank %}
                  <div class="ai-holo-slider__vendor-{{ ai_gen_id }}">{{ product.vendor }}</div>
                {% endif %}

                <h3 class="ai-holo-slider__product-title-{{ ai_gen_id }}">
                  <a href="{{ product.url }}" style="color: inherit; text-decoration: none;">
                    {{ product.title }}
                  </a>
                </h3>

                {% if block.settings.show_price %}
                  <div class="ai-holo-slider__price-{{ ai_gen_id }}">
                    <span class="ai-holo-slider__price-current-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </span>
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-holo-slider__price-compare-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_button %}
                  <a href="{{ product.url }}" class="ai-holo-slider__button-{{ ai_gen_id }}">
                    {{ block.settings.button_text }}
                  </a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if block.settings.show_navigation %}
        <div class="ai-holo-slider__nav-{{ ai_gen_id }}">
          <button class="ai-holo-slider__nav-button-{{ ai_gen_id }}" data-prev aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>

          {% if block.settings.show_dots %}
            <div class="ai-holo-slider__dots-{{ ai_gen_id }}" data-dots></div>
          {% endif %}

          <button class="ai-holo-slider__nav-button-{{ ai_gen_id }}" data-next aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-holo-slider__empty-state-{{ ai_gen_id }}">
        <div class="ai-holo-slider__empty-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
        <p>Add products to display in the slider</p>
      </div>
    {% endif %}
  </div>
</holographic-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class HolographicSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('[data-slider-track]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.currentIndex = 0;
        this.cardsPerView = {{ block.settings.cards_per_row_desktop }};
      }

      connectedCallback() {
        if (!this.track) return;

        this.updateCardsPerView();
        this.createDots();
        this.setupEventListeners();
        this.updateNavigation();

        window.addEventListener('resize', () => {
          this.updateCardsPerView();
          this.createDots();
        });
      }

      updateCardsPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.cardsPerView = {{ block.settings.cards_per_row_mobile }};
        } else if (width <= 989) {
          this.cardsPerView = {{ block.settings.cards_per_row_tablet }};
        } else {
          this.cardsPerView = {{ block.settings.cards_per_row_desktop }};
        }
      }

      createDots() {
        if (!this.dotsContainer) return;

        const cards = this.track.children;
        const totalDots = Math.ceil(cards.length / this.cardsPerView);

        this.dotsContainer.innerHTML = '';

        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-holo-slider__dot-{{ ai_gen_id }}';
          dot.setAttribute('aria-label', 'Go to slide ' + (i + 1));
          if (i === 0) dot.classList.add('active');

          dot.addEventListener('click', () => {
            this.currentIndex = i;
            this.scrollToIndex(i);
          });

          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.prev());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.next());
        }

        this.track.addEventListener('scroll', () => {
          this.updateDotsFromScroll();
        });

        let startX = 0;
        let scrollLeft = 0;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].pageX;
          scrollLeft = this.track.scrollLeft;
        });

        this.track.addEventListener('touchmove', (e) => {
          const x = e.touches[0].pageX;
          const walk = (startX - x) * 2;
          this.track.scrollLeft = scrollLeft + walk;
        });
      }

      prev() {
        if (this.currentIndex > 0) {
          this.currentIndex--;
          this.scrollToIndex(this.currentIndex);
        }
      }

      next() {
        const cards = this.track.children;
        const maxIndex = Math.ceil(cards.length / this.cardsPerView) - 1;

        if (this.currentIndex < maxIndex) {
          this.currentIndex++;
          this.scrollToIndex(this.currentIndex);
        }
      }

      scrollToIndex(index) {
        const card = this.track.children[0];
        if (!card) return;

        const cardWidth = card.offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollAmount = (cardWidth + gap) * this.cardsPerView * index;

        this.track.scrollTo({
          left: scrollAmount,
          behavior: 'smooth'
        });

        this.updateDots(index);
        this.updateNavigation();
      }

      updateDotsFromScroll() {
        const card = this.track.children[0];
        if (!card) return;

        const cardWidth = card.offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const scrollLeft = this.track.scrollLeft;
        const index = Math.round(scrollLeft / ((cardWidth + gap) * this.cardsPerView));

        if (index !== this.currentIndex) {
          this.currentIndex = index;
          this.updateDots(index);
          this.updateNavigation();
        }
      }

      updateDots(index) {
        if (!this.dotsContainer) return;

        const dots = this.dotsContainer.querySelectorAll('.ai-holo-slider__dot-{{ ai_gen_id }}');
        dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      updateNavigation() {
        const cards = this.track.children;
        const maxIndex = Math.ceil(cards.length / this.cardsPerView) - 1;

        if (this.prevButton) {
          this.prevButton.disabled = this.currentIndex === 0;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentIndex >= maxIndex;
        }
      }
    }

    customElements.define('holographic-slider-{{ ai_gen_id }}', HolographicSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Holographic slider",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "inline_richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest collection"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "cards_per_row_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Cards per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "cards_per_row_tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Cards per row (tablet)",
      "default": 3
    },
    {
      "type": "select",
      "id": "cards_per_row_mobile",
      "label": "Cards per row (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "header",
      "content": "Holographic effect"
    },
    {
      "type": "range",
      "id": "holographic_opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Effect opacity",
      "default": 30
    },
    {
      "type": "range",
      "id": "holographic_angle",
      "min": 0,
      "max": 360,
      "step": 15,
      "unit": "deg",
      "label": "Gradient angle",
      "default": 135
    },
    {
      "type": "color",
      "id": "holo_color_1",
      "label": "Color 1",
      "default": "#ff00ff"
    },
    {
      "type": "color",
      "id": "holo_color_2",
      "label": "Color 2",
      "default": "#00ffff"
    },
    {
      "type": "color",
      "id": "holo_color_3",
      "label": "Color 3",
      "default": "#ffff00"
    },
    {
      "type": "color",
      "id": "holo_color_4",
      "label": "Color 4",
      "default": "#ff00ff"
    },
    {
      "type": "select",
      "id": "blend_mode",
      "label": "Blend mode",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "screen", "label": "Screen" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "color", "label": "Color" },
        { "value": "luminosity", "label": "Luminosity" }
      ],
      "default": "overlay"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
