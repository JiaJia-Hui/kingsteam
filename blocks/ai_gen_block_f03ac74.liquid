{% doc %}
  @prompt
    An 4:1 image taking up all the space in the background, with a rich text in the center. The text font and style follows global setting.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-hero-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 25%;
    background-color: #f4f4f4;
  }

  .ai-hero-banner__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 0 20px;
    text-align: center;
    z-index: 2;
  }

  .ai-hero-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner__text-{{ ai_gen_id }} h1,
  .ai-hero-banner__text-{{ ai_gen_id }} h2,
  .ai-hero-banner__text-{{ ai_gen_id }} h3,
  .ai-hero-banner__text-{{ ai_gen_id }} h4,
  .ai-hero-banner__text-{{ ai_gen_id }} h5,
  .ai-hero-banner__text-{{ ai_gen_id }} h6 {
    color: {{ block.settings.text_color }};
    margin-top: 0;
  }

  .ai-hero-banner__text-{{ ai_gen_id }} p {
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner__text-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 50%;
    }

    .ai-hero-banner__content-{{ ai_gen_id }} {
      max-width: 100%;
      padding: 0 16px;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
        class="ai-hero-banner__image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-hero-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
          Next, add a background image
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-hero-banner__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-hero-banner__content-{{ ai_gen_id }}">
      {% if block.settings.text != blank %}
        <div class="ai-hero-banner__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<h2>Welcome to our store</h2><p>Discover amazing products</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Content max width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ],
  "tag": null
}
{% endschema %}
